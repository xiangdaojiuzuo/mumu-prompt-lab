<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="248dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/panel_background">

    <LinearLayout
        android:id="@+id/dragHandle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/symbolText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="等待畫面"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/closeOverlay"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="×"
            android:textColor="#DDE6F4"
            android:textSize="25sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/signalText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="⚪ 資訊不足"
        android:textColor="#CFD8DC"
        android:textSize="19sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/detailText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:lineSpacingExtra="3dp"
        android:text="請切到個股報價或 K 線頁面"
        android:textColor="#BBC7D8"
        android:textSize="14sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="僅供輔助｜本人確認下單"
        android:textColor="#718096"
        android:textSize="11sp" />
</LinearLayout>
